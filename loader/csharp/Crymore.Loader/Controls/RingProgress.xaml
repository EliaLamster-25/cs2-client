<UserControl x:Class="Crymore.Loader.Controls.RingProgress"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="14" Height="14"
             Visibility="Collapsed">
  <Grid>
    <Ellipse Width="12" Height="12"
             Stroke="#55FFFFFF"
             StrokeThickness="1.5"
             Fill="Transparent"/>
    <Grid x:Name="ArcHost" RenderTransformOrigin="0.5,0.5">
      <Grid.RenderTransform>
        <RotateTransform x:Name="SpinTransform" Angle="0"/>
      </Grid.RenderTransform>
      <Ellipse x:Name="ArcEllipse"
               Width="12" Height="12"
               Stroke="#EEEEF4"
               StrokeThickness="1.5"
               Fill="Transparent"
               StrokeDashCap="Round"
               RenderTransformOrigin="0.5,0.5">
        <Ellipse.RenderTransform>
          <RotateTransform Angle="-90"/>
        </Ellipse.RenderTransform>
      </Ellipse>
    </Grid>
  </Grid>
</UserControl>
