<Window x:Class="Crymore.Loader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Crymore.Loader.Controls"
        Title="crymore.pw"
        Width="380" Height="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

  <Window.Resources>
    <Thickness x:Key="LoginItemGap">0,0,0,12</Thickness>

    <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                       From="1" To="0.4" Duration="0:0:0.55"
                       AutoReverse="True"/>
    </Storyboard>

    <Storyboard x:Key="PageInStoryboard">
      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                       From="0" To="1" Duration="0:0:0.28">
        <DoubleAnimation.EasingFunction>
          <QuadraticEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                       From="10" To="0" Duration="0:0:0.28">
        <DoubleAnimation.EasingFunction>
          <QuadraticEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
    </Storyboard>
  </Window.Resources>

  <Border x:Name="ShellBorder"
          Background="{StaticResource BgBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="8"
          SizeChanged="ShellBorder_SizeChanged">

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="28"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Titlebar -->
      <Border Grid.Row="0"
              Background="#07080D"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,0,1"
              CornerRadius="8,8,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid Margin="12,0,8,0">
          <TextBlock x:Name="TitleLabel"
                     Text="crymore.pw"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource UiFont}"
                     FontSize="11"
                     Foreground="{StaticResource DimBrush}"/>
          <TextBlock x:Name="BuildVersionLabel"
                     Text="v0.0.0"
                     HorizontalAlignment="Right"
                     Margin="0,0,34,0"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="10"
                     Foreground="{StaticResource DimBrush}"/>
          <Button HorizontalAlignment="Right"
                  Width="24" Height="20"
                  Click="CloseButton_Click"
                  Cursor="Hand">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="Bd" CornerRadius="3" Background="Transparent">
                  <Path Data="M1,1 L8,8 M8,1 L1,8"
                        Stroke="{StaticResource DimBrush}"
                        StrokeThickness="1.2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#1A1218"/>
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#332030"/>
                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </Grid>
      </Border>

      <Grid Grid.Row="1">

        <!-- LOGIN -->
        <Grid x:Name="LoginPage" Visibility="Visible">
          <Grid.RenderTransform>
            <TranslateTransform/>
          </Grid.RenderTransform>

          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" VerticalAlignment="Center" MinHeight="220">
            <Image x:Name="LogoBlurLarge"
                   Width="280" Height="280"
                   HorizontalAlignment="Center"
                   Opacity="0.12"
                   RenderOptions.BitmapScalingMode="Fant">
              <Image.Effect>
                <BlurEffect Radius="32"/>
              </Image.Effect>
            </Image>
            <Image x:Name="LogoBlurMid"
                   Width="200" Height="200"
                   HorizontalAlignment="Center"
                   Opacity="0.35"
                   RenderOptions.BitmapScalingMode="Fant">
              <Image.Effect>
                <BlurEffect Radius="12"/>
              </Image.Effect>
            </Image>
            <Image x:Name="LogoMain"
                   Width="120" Height="120"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="Fant"/>
          </Grid>

          <StackPanel Grid.Row="1" Margin="32,8,32,32">
            <TextBox x:Name="UsernameBox"
                     Style="{StaticResource FieldBox}"
                     Margin="{StaticResource LoginItemGap}"/>

            <Grid Margin="{StaticResource LoginItemGap}">
              <PasswordBox x:Name="PasswordInput"
                           Style="{StaticResource FieldPassword}"/>
              <TextBlock x:Name="PasswordWatermark"
                         Text="password"
                         Foreground="{StaticResource DimBrush}"
                         FontFamily="{StaticResource UiFont}"
                         FontSize="13"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False"/>
            </Grid>

            <CheckBox x:Name="RememberMeBox"
                      Content="remember me"
                      Style="{StaticResource RememberCheck}"
                      Margin="1,0,0,12"
                      HorizontalAlignment="Left"/>

            <TextBlock x:Name="LoginErrorText"
                       Text=""
                       Foreground="{StaticResource BadBrush}"
                       FontSize="11"
                       TextAlignment="Center"
                       Margin="{StaticResource LoginItemGap}"
                       TextWrapping="Wrap"
                       MinHeight="16"/>

            <Button x:Name="LoginButton"
                    Content="login"
                    Style="{StaticResource PrimaryButton}"
                    Click="LoginButton_Click"/>
          </StackPanel>
        </Grid>

        <!-- MAIN -->
        <Grid x:Name="StatusPage" Visibility="Collapsed" Margin="22,16,22,20">
          <Grid.RenderTransform>
            <TranslateTransform/>
          </Grid.RenderTransform>

          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Grid Grid.Column="0" Margin="0,0,14,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="16,14">
              <StackPanel>
                <TextBlock Text="run state"
                           Style="{StaticResource MutedText}"
                           FontSize="10"
                           Margin="0,0,0,14"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                  <Ellipse x:Name="DotLoggedIn" Width="6" Height="6" Fill="{StaticResource OkBrush}" Margin="0,0,10,0"/>
                  <TextBlock x:Name="TxtLoggedIn" Text="logged in" Style="{StaticResource TitleText}" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                  <Ellipse x:Name="DotLoading" Width="6" Height="6" Fill="{StaticResource DimBrush}" Margin="0,0,10,0"/>
                  <TextBlock x:Name="TxtLoading" Text="loading" Style="{StaticResource MutedText}" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                  <Ellipse x:Name="DotLoaded" Width="6" Height="6" Fill="{StaticResource DimBrush}" Margin="0,0,10,0"/>
                  <TextBlock x:Name="TxtLoaded" Text="loaded" Style="{StaticResource MutedText}" FontSize="13"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- brand + updates -->
            <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="14,12" Margin="0,10,0,10">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,12">
                  <Image x:Name="SideLogo"
                         Width="52" Height="52"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,6"
                         RenderOptions.BitmapScalingMode="Fant"/>
                  <TextBlock Text="rebirth"
                             Style="{StaticResource MutedText}"
                             FontSize="11"
                             HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                  <TextBlock Text="updates"
                             Style="{StaticResource MutedText}"
                             FontSize="10"
                             Margin="0,0,0,8"/>
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="UpdateLogText"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="#7A7C94"
                               TextWrapping="Wrap"
                               LineHeight="15"/>
                  </ScrollViewer>
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="12,11">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="38" Height="38" CornerRadius="4"
                        Background="#090A0F"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        ClipToBounds="True">
                  <Image x:Name="ProfileLogo"
                         Margin="4"
                         RenderOptions.BitmapScalingMode="Fant"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                  <TextBlock x:Name="ProfileUser" Text="demo"
                             Style="{StaticResource TitleText}" FontSize="14"/>
                  <TextBlock x:Name="ProfilePlan" Text="active"
                             Style="{StaticResource MutedText}" FontSize="11" Margin="0,1,0,0"/>
                  <TextBlock x:Name="ProfileExpiry" Text="—"
                             Style="{StaticResource MutedText}" FontSize="10" Margin="0,1,0,0"/>
                </StackPanel>
              </Grid>
            </Border>
          </Grid>

          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="16,14" Margin="0,0,0,10">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                  <Ellipse x:Name="LaunchDot" Width="6" Height="6"
                           Fill="{StaticResource OkBrush}" Margin="0,5,8,0"/>
                  <TextBlock x:Name="LaunchTitle" Text="ready"
                             Style="{StaticResource TitleText}" FontSize="15"/>
                </StackPanel>
                <TextBlock x:Name="LaunchDesc"
                           Text="checks passed"
                           Style="{StaticResource MutedText}"
                           FontSize="12"
                           Margin="14,0,0,16"
                           TextWrapping="Wrap"/>
                <Button x:Name="InjectButton"
                        Style="{StaticResource PrimaryButton}"
                        Click="InjectButton_Click">
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <controls:RingProgress x:Name="InjectRing"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                    <TextBlock x:Name="InjectLabel"
                               Text="inject"
                               VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="14,12">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="log"
                           Style="{StaticResource MutedText}"
                           FontSize="10"
                           Margin="0,0,0,8"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                  <TextBlock x:Name="LogText"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="10.5"
                             Foreground="#7A7C94"
                             TextWrapping="Wrap"
                             LineHeight="16"/>
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
