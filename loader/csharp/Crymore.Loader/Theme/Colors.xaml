<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="BgColor">#0B0C12</Color>
  <Color x:Key="SurfaceColor">#0D0E14</Color>
  <Color x:Key="Surface2Color">#12141C</Color>
  <Color x:Key="BorderColor">#1C1E28</Color>
  <Color x:Key="Border2Color">#252838</Color>
  <Color x:Key="AccentColor">#7674F4</Color>
  <Color x:Key="AccentHiColor">#8B89F8</Color>
  <Color x:Key="AccentDkColor">#5A58C9</Color>
  <Color x:Key="InkColor">#D8D9E9</Color>
  <Color x:Key="MutedColor">#6E7087</Color>
  <Color x:Key="DimColor">#454862</Color>
  <Color x:Key="OkColor">#5BC48A</Color>
  <Color x:Key="BadColor">#B94261</Color>
  <Color x:Key="WarnColor">#D4A853</Color>

  <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
  <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="Border2Brush" Color="{StaticResource Border2Color}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="AccentHiBrush" Color="{StaticResource AccentHiColor}"/>
  <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}"/>
  <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>
  <SolidColorBrush x:Key="DimBrush" Color="{StaticResource DimColor}"/>
  <SolidColorBrush x:Key="OkBrush" Color="{StaticResource OkColor}"/>
  <SolidColorBrush x:Key="BadBrush" Color="{StaticResource BadColor}"/>
  <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}"/>

</ResourceDictionary>
